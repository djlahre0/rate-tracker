# ---------------------------------------------------------------------------
# Rate-Tracker environment. Copy to .env (never commit .env) and adjust.
# The app fails fast on startup if any required variable below is missing.
# Values here are the docker-compose defaults (service hostnames db / redis).
# Comments stay on their own lines so every Compose version parses env_file cleanly.
# ---------------------------------------------------------------------------

# --- Django (required) ---
# Cryptographic signing key — set to a long random string.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Never true in production.
DJANGO_DEBUG=false
# Comma-separated allowed hostnames.
DJANGO_ALLOWED_HOSTS=*

# --- Ingest webhook auth (required) ---
# Bearer token for POST /api/rates/ingest.
INGEST_API_TOKEN=change-me-bearer-token

# --- PostgreSQL (required) ---
# A single DATABASE_URL (managed hosts like Railway/Neon supply one) takes
# precedence when set; otherwise the discrete POSTGRES_* vars below are used.
# DATABASE_URL=postgres://user:password@host:5432/dbname
POSTGRES_DB=ratetracker
POSTGRES_USER=rates
POSTGRES_PASSWORD=change-me-db-password
# Compose service name; use 127.0.0.1 for a local (non-docker) venv.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis: cache + Celery broker/backend (required) ---
# Use redis://127.0.0.1:PORT for a local venv.
REDIS_URL=redis://redis:6379/0

# --- CORS: which origins may call the API (optional) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Domain knobs (optional) ---
# Rates above this percent are quarantined as impossible outliers.
RATE_OUTLIER_CEILING=25
# Log a warning for any SQL query slower than this many seconds.
SLOW_QUERY_SECONDS=0.2
# Celery Beat cadence (seconds) for scheduled ingestion.
INGEST_INTERVAL_SECONDS=3600
# Run Celery tasks synchronously in-process (true only for tests/debugging).
CELERY_TASK_ALWAYS_EAGER=false
# Bound the scheduled re-ingest to keep a free-tier deploy light. Empty = full
# history (local default). SEED_SINCE is a fixed ISO date (recommended for the
# static seed, whose dense data ends well before "today"); SEED_SINCE_DAYS is a
# clock-relative fallback. SEED_SINCE wins when both are set. See DEPLOY.md.
SEED_SINCE=
SEED_SINCE_DAYS=0

# --- Frontend (required by the frontend build) ---
# Host-reachable API URL baked into the browser bundle at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000
