# Normalize all text to LF in the repo AND on checkout (critical: shell scripts
# like backend/entrypoint.sh must stay LF or Docker containers fail to start on
# Windows clones where core.autocrlf=true).
* text=auto eol=lf

# Explicit LF for scripts, regardless of platform.
*.sh text eol=lf
entrypoint.sh text eol=lf

# Binary files — never touch line endings.
*.parquet binary
*.png binary
*.jpg binary
*.ico binary
*.docx binary
